# .gitignore for FloraGuard

# Don't commit the massive PlantVillage dataset (50k images = GitHub will reject it)
raw_data/PlantVillage/

# Don't commit personal garden photos either (privacy + file size)
raw_data/My_Garden/

# Don't commit processed images (they can be regenerated by running preprocess.py)
processed_data/

# Don't commit trained model files (too large for GitHub)
models/

# Python cache files (auto-generated, not your code)
__pycache__/
*.pyc
*.pyo

# VS Code settings (personal preference, not project code)
.vscode/

# Jupyter notebook checkpoints
.ipynb_checkpoints/